package build

import mill._
import mill.scalalib._
import mill.contrib.buildinfo.BuildInfo
import mill.contrib.scoverage._

object fdlog extends ScalaModule with ScoverageModule with BuildInfo {
  def scalaVersion = "3.7.4"

  val majorVersion = "0"
  val version      = s"$majorVersion.0.0"
  def mainClass    = Some("fdlog.FdLogApp")

  val name = "fdswarm"

  def buildInfoPackageName = "com.organization"

  def buildInfoMembers = Seq(
    BuildInfo.Value("name",         name),
    BuildInfo.Value("version",      version),
    BuildInfo.Value("majorVersion",      majorVersion),
    BuildInfo.Value("scalaVersion", scalaVersion())
  )

  def scoverageVersion = "2.1.1"
  val log4jV = "2.24.2"

  def mvnDeps = Seq(
    mvn"com.typesafe.scala-logging::scala-logging:3.9.5",

    // SLF4J API
    mvn"org.slf4j:slf4j-api:2.0.16",

    // Log4j2 API + core (needed for org.apache.logging.log4j.core.*)
    mvn"org.apache.logging.log4j:log4j-api:$log4jV",
    mvn"org.apache.logging.log4j:log4j-core:$log4jV",

    // SLF4J 2.x → Log4j2 bridge
    mvn"org.apache.logging.log4j:log4j-slf4j2-impl:$log4jV",

    mvn"com.fasterxml.jackson.core:jackson-databind:2.17.2",
    mvn"com.fasterxml.jackson.dataformat:jackson-dataformat-yaml:2.17.2",
    
    mvn"io.github.classgraph:classgraph:4.8.179",
    mvn"net.codingwell::scala-guice:7.0.0",

    mvn"com.lihaoyi::cask:0.11.3",
    mvn"com.lihaoyi::upickle:4.4.2",
    mvn"com.lihaoyi::os-lib:0.11.6",
    mvn"com.lihaoyi::requests:0.9.0",
    mvn"com.lihaoyi::scalatags:0.13.1",
    mvn"org.apache.commons:commons-text:1.10.0",
    mvn"com.google.inject:guice:7.0.0",
    mvn"net.codingwell:scala-guice_3:7.0.0",
    mvn"com.github.andyglow::typesafe-config-scala:2.0.0",

    mvn"org.scalafx:scalafx_3:23.0.1-R34",

  )


  object test extends ScoverageTests with TestModule.Munit {

    override def mvnDeps = super.mvnDeps() ++ Seq(
      mvn"org.apache.logging.log4j:log4j-core:$log4jV",
      mvn"org.apache.logging.log4j:log4j-core-test:$log4jV",
    )
    def scalaVersion = "3.7.1"
    def munitVersion = "1.0.0"
  }

}